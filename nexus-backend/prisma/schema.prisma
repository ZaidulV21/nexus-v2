generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?
  passwordHash String
  roleId       String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  role         Role      @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model TimelineEvent {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  eventType   String
  description String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("timeline_events")
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  actorUserId String?
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model NotificationEvent {
  id         String            @id @default(uuid())
  eventType  String
  entityType String?
  entityId   String?
  payload    Json
  createdAt  DateTime          @default(now())
  logs       NotificationLog[]

  @@map("notification_events")
}

model NotificationLog {
  id                  String            @id @default(uuid())
  notificationEventId String
  channel             String
  recipient           String
  status              String
  sentAt              DateTime?
  errorMessage        String?
  createdAt           DateTime          @default(now())
  notificationEvent   NotificationEvent @relation(fields: [notificationEventId], references: [id])

  @@map("notification_logs")
}

model InAppNotification {
  id              String    @id @default(uuid())
  recipientId     String
  recipientType   String
  title           String
  description     String
  type            String    @default("INFO")
  priority        String    @default("NORMAL")
  relatedEntity   String?
  relatedEntityId String?
  actionUrl       String?
  isRead          Boolean   @default(false)
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([recipientId, recipientType])
  @@index([recipientId, recipientType, isRead])
  @@map("in_app_notifications")
}

model StatusTransitionLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  fromStatus  String?
  toStatus    String
  actorUserId String?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("status_transitions_log")
}

model Category {
  id               String     @id @default(uuid())
  name             String
  parentCategoryId String?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children         Category[] @relation("CategoryHierarchy")
  services         Service[]

  @@map("categories")
}

model Service {
  id                String                 @id @default(uuid())
  categoryId        String
  name              String
  description       String?
  icon              String?
  basePrice         Decimal?               @db.Decimal(12, 2)
  requiresSiteVisit SiteVisitRequirement   @default(OPTIONAL)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  archivedAt        DateTime?
  estimatedDuration String?
  leadServices      LeadService[]
  projectServices   ProjectService[]
  questionnaires    ServiceQuestionnaire[]
  category          Category               @relation(fields: [categoryId], references: [id])

  @@map("services")
}

model ServiceQuestionnaire {
  id           String        @id @default(uuid())
  serviceId    String
  schema       Json
  version      Int
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  leadServices LeadService[]
  service      Service       @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, version])
  @@map("service_questionnaires")
}

model Lead {
  id            String             @id @default(uuid())
  leadNumber    String             @unique
  contactName   String
  phone         String
  email         String?
  companyName   String?
  source        String             @default("WEBSITE")
  convertedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  archivedAt    DateTime?
  archivedById  String?
  archiveReason String?
  client        Client?
  activityNotes LeadActivityNote[]
  leadServices  LeadService[]
  projects      Project[]
  quotations    Quotation[]

  @@map("leads")
}

model LeadService {
  id                        String                @id @default(uuid())
  leadId                    String
  serviceId                 String
  status                    String                @default("NEW")
  questionnaireVersionId    String?
  questionnaireAnswers      Json?
  siteVisitRequiredOverride Boolean?
  siteVisitOverrideReason   String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  lead                      Lead                  @relation(fields: [leadId], references: [id])
  questionnaireVersion      ServiceQuestionnaire? @relation(fields: [questionnaireVersionId], references: [id])
  service                   Service               @relation(fields: [serviceId], references: [id])
  projectServices           ProjectService[]

  @@map("lead_services")
}

model LeadActivityNote {
  id           String   @id @default(uuid())
  leadId       String
  authorUserId String
  note         String
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id])

  @@map("lead_activity_notes")
}

model Client {
  id            String         @id @default(uuid())
  companyName   String?
  contactName   String
  phone         String
  email         String         @unique
  passwordHash  String
  sourceLeadId  String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  clientNumber  String         @unique
  gstin         String?
  sourceLead    Lead           @relation(fields: [sourceLeadId], references: [id])
  conversations Conversation[]
  documents     Document[]
  invoices      Invoice[]
  projects      Project[]
  quotations    Quotation[]

  @@map("clients")
}

model Quotation {
  id                 String             @id @default(uuid())
  quotationNumber    String             @unique
  leadId             String?
  clientId           String?
  status             QuotationStatus    @default(DRAFT)
  activeVersionId    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  pdfUrl             String?
  pdfGeneratedAt     DateTime?          @db.Timestamptz(6)
  validUntil         DateTime?
  notes              String?
  termsAndConditions String?
  paymentTerms       String?
  versions           QuotationVersion[]
  client             Client?            @relation(fields: [clientId], references: [id])
  lead               Lead?              @relation(fields: [leadId], references: [id])

  @@map("quotations")
}

model QuotationVersion {
  id              String              @id @default(uuid())
  quotationId     String
  versionNumber   Int
  isActive        Boolean             @default(true)
  subtotal        Decimal             @db.Decimal(12, 2)
  discount        Decimal             @default(0) @db.Decimal(12, 2)
  gstAmount       Decimal             @default(0) @db.Decimal(12, 2)
  transportation  Decimal             @default(0) @db.Decimal(12, 2)
  installation    Decimal             @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal             @db.Decimal(12, 2)
  createdByUserId String
  createdAt       DateTime            @default(now())
  projectServices ProjectService[]
  approvals       QuotationApproval[]
  items           QuotationItem[]
  quotation       Quotation           @relation(fields: [quotationId], references: [id])

  @@unique([quotationId, versionNumber])
  @@map("quotation_versions")
}

model QuotationItem {
  id                 String           @id @default(uuid())
  quotationVersionId String
  serviceId          String
  description        String
  quantity           Decimal          @db.Decimal(10, 2)
  unitPrice          Decimal          @db.Decimal(12, 2)
  taxRate            Decimal          @db.Decimal(5, 2)
  taxAmount          Decimal          @db.Decimal(12, 2)
  lineTotal          Decimal          @db.Decimal(12, 2)
  serviceName        String?
  hsnSacCode         String?
  quotationVersion   QuotationVersion @relation(fields: [quotationVersionId], references: [id])

  @@map("quotation_items")
}

model QuotationApproval {
  id                 String           @id @default(uuid())
  quotationVersionId String
  approvedByUserId   String
  approvalMethod     ApprovalMethod
  approvedAt         DateTime         @default(now())
  quotationVersion   QuotationVersion @relation(fields: [quotationVersionId], references: [id])

  @@map("quotation_approvals")
}

model Project {
  id              String           @id @default(uuid())
  projectNumber   String           @unique
  leadId          String
  clientId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  conversations   Conversation[]
  documents       Document[]
  invoices        Invoice[]
  projectServices ProjectService[]
  client          Client           @relation(fields: [clientId], references: [id])
  lead            Lead             @relation(fields: [leadId], references: [id])

  @@map("projects")
}

model ProjectService {
  id                         String            @id @default(uuid())
  projectId                  String
  serviceId                  String
  leadServiceId              String?
  status                     String            @default("PROJECT CREATED")
  assignedQuotationVersionId String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  assignedQuotationVersion   QuotationVersion? @relation(fields: [assignedQuotationVersionId], references: [id])
  leadService                LeadService?      @relation(fields: [leadServiceId], references: [id])
  project                    Project           @relation(fields: [projectId], references: [id])
  service                    Service           @relation(fields: [serviceId], references: [id])

  @@map("project_services")
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  projectId       String
  clientId        String
  label           String
  status          InvoiceStatus @default(ISSUED)
  cancelReason    String?
  subtotal        Decimal       @db.Decimal(12, 2)
  gstAmount       Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal       @db.Decimal(12, 2)
  issuedAt        DateTime      @default(now())
  createdByUserId String
  pdfUrl          String?
  pdfGeneratedAt  DateTime?     @db.Timestamptz(6)
  items           InvoiceItem[]
  client          Client        @relation(fields: [clientId], references: [id])
  project         Project       @relation(fields: [projectId], references: [id])
  payments        Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  hsnSacCode  String
  taxRate     Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id               String   @id @default(uuid())
  invoiceId        String
  amount           Decimal  @db.Decimal(12, 2)
  method           String
  referenceNote    String?
  recordedByUserId String
  paidAt           DateTime @default(now())
  invoice          Invoice  @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model InvoiceNumberSequence {
  id            String @id @default(uuid())
  financialYear String @unique
  lastNumber    Int    @default(0)

  @@map("invoice_number_sequences")
}

model Document {
  id               String    @id @default(uuid())
  entityType       String
  entityId         String
  documentType     String
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String
  uploadedByUserId String
  clientId         String?
  projectRefId     String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  client           Client?   @relation(fields: [clientId], references: [id])
  projectRef       Project?  @relation(fields: [projectRefId], references: [id])

  @@index([entityType, entityId])
  @@map("documents")
}

model Conversation {
  id        String    @id @default(uuid())
  clientId  String
  projectId String?
  createdAt DateTime  @default(now())
  client    Client    @relation(fields: [clientId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderType     String
  senderUserId   String?
  senderClientId String?
  body           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

model CompanySetting {
  id                  String   @id @default("singleton")
  companyName         String?
  legalBusinessName   String?
  logoUrl             String?
  faviconUrl          String?
  gstNumber           String?
  panNumber           String?
  cin                 String?
  email               String?
  phone               String?
  whatsappNumber      String?
  website             String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  country             String?
  pincode             String?
  currency            String?  @default("INR")
  currencySymbol      String?  @default("₹")
  timezone            String?  @default("Asia/Kolkata")
  dateFormat          String?  @default("dd/MM/yyyy")
  invoicePrefix       String?  @default("INV")
  quotationPrefix     String?  @default("QUO")
  projectPrefix       String?  @default("PRJ")
  clientPrefix        String?  @default("CLI")
  leadPrefix          String?  @default("LD")
  defaultGstPercent   Decimal? @default(18) @db.Decimal(5, 2)
  defaultPaymentTerms String?
  companySignatureUrl String?
  companyStampUrl     String?
  bankName            String?
  accountHolder       String?
  accountNumber       String?
  ifsc                String?
  branch              String?
  upiId               String?
  qrCodeUrl           String?
  senderName          String?
  replyToEmail        String?
  supportEmail        String?
  facebook            String?
  instagram           String?
  linkedin            String?
  twitter             String?
  youtube             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("company_settings")
}

enum SiteVisitRequirement {
  YES
  NO
  OPTIONAL
}

enum QuotationStatus {
  DRAFT
  SENT
  NEGOTIATION
  APPROVED
  REJECTED
  ACCEPTED
}

enum ApprovalMethod {
  PHONE
  WHATSAPP
  EMAIL
  IN_PERSON
}

enum InvoiceStatus {
  ISSUED
  CANCELLED
}
