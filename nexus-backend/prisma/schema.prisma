generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================================
// M1 - AUTH & USERS
// ==========================================================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?
  passwordHash String
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

// Explicit junction table between Role and Permission. No relation to User -
// permission checks always go through a User's roleId -> Role -> RolePermission,
// never a direct User<->Permission or User<->RolePermission link.
model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================================================
// M2 - TIMELINE & AUDIT LOG
// ==========================================================================

model TimelineEvent {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  eventType   String
  description String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("timeline_events")
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  actorUserId String?
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ==========================================================================
// M3 - NOTIFICATION CORE
// ==========================================================================

model NotificationEvent {
  id         String   @id @default(uuid())
  eventType  String
  entityType String?
  entityId   String?
  payload    Json
  createdAt  DateTime @default(now())

  logs NotificationLog[]

  @@map("notification_events")
}

model NotificationLog {
  id                   String   @id @default(uuid())
  notificationEventId  String
  notificationEvent    NotificationEvent @relation(fields: [notificationEventId], references: [id])
  channel              String
  recipient            String
  status               String   // SENT | FAILED
  sentAt               DateTime?
  errorMessage         String?
  createdAt            DateTime @default(now())

  @@map("notification_logs")
}

// ==========================================================================
// M4 - STATUS ENGINE
// ==========================================================================

model StatusTransitionLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  fromStatus  String?
  toStatus    String
  actorUserId String?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("status_transitions_log")
}

// ==========================================================================
// M5 - SERVICE CATALOG
// ==========================================================================

enum SiteVisitRequirement {
  YES
  NO
  OPTIONAL
}

model Category {
  id               String     @id @default(uuid())
  name             String
  parentCategoryId String?
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children         Category[] @relation("CategoryHierarchy")
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  services Service[]

  @@map("categories")
}

model Service {
  id                 String   @id @default(uuid())
  categoryId         String
  category           Category @relation(fields: [categoryId], references: [id])
  name               String
  description        String?
  icon               String?
  basePrice          Decimal? @db.Decimal(12, 2)
  estimatedDuration  String?
  requiresSiteVisit  SiteVisitRequirement @default(OPTIONAL)
  isActive           Boolean  @default(true)
  archivedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  questionnaires  ServiceQuestionnaire[]
  leadServices    LeadService[]
  projectServices ProjectService[]

  @@map("services")
}

model ServiceQuestionnaire {
  id        String   @id @default(uuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  schema    Json
  version   Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  leadServices LeadService[]

  @@unique([serviceId, version])
  @@map("service_questionnaires")
}

// ==========================================================================
// M6 - LEAD MODULE
// ==========================================================================

model Lead {
  id            String    @id @default(uuid())
  leadNumber    String    @unique
  contactName   String
  phone         String
  email         String?
  companyName   String?
  source        String    @default("WEBSITE")
  convertedAt   DateTime?
  archivedAt    DateTime?
  archivedById  String?
  archiveReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  leadServices  LeadService[]
  activityNotes LeadActivityNote[]
  client        Client?
  quotations    Quotation[]
  projects      Project[]

  @@map("leads")
}

model LeadService {
  id                       String    @id @default(uuid())
  leadId                   String
  lead                     Lead      @relation(fields: [leadId], references: [id])
  serviceId                String
  service                  Service   @relation(fields: [serviceId], references: [id])
  status                   String    @default("NEW")
  questionnaireVersionId   String?
  questionnaireVersion     ServiceQuestionnaire? @relation(fields: [questionnaireVersionId], references: [id])
  questionnaireAnswers     Json?
  siteVisitRequiredOverride Boolean?
  siteVisitOverrideReason  String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  projectServices ProjectService[]

  @@map("lead_services")
}

model LeadActivityNote {
  id           String   @id @default(uuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id])
  authorUserId String
  note         String
  createdAt    DateTime @default(now())

  @@map("lead_activity_notes")
}

// ==========================================================================
// M7 - CLIENT MODULE
// ==========================================================================

model Client {
  id           String    @id @default(uuid())
  clientNumber String    @unique
  companyName  String?
  contactName  String
  phone        String
  email        String    @unique
  passwordHash String
  sourceLeadId String    @unique
  sourceLead   Lead      @relation(fields: [sourceLeadId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  quotations    Quotation[]
  projects      Project[]
  invoices      Invoice[]
  documents     Document[]
  conversations Conversation[]

  @@map("clients")
}

// ==========================================================================
// M8 - QUOTATION MODULE
// ==========================================================================

enum QuotationStatus {
  DRAFT
  SENT
  NEGOTIATION
  APPROVED
  ACCEPTED
  REJECTED
}

enum ApprovalMethod {
  PHONE
  WHATSAPP
  EMAIL
  IN_PERSON
}

model Quotation {
  id               String          @id @default(uuid())
  quotationNumber  String          @unique
  // Exactly one of leadId / clientId is populated at a time: leadId while
  // the customer is still a Lead, clientId after conversion (quotations are
  // migrated automatically when the Lead becomes a Client).
  leadId           String?
  lead             Lead?           @relation(fields: [leadId], references: [id])
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])
  status           QuotationStatus @default(DRAFT)
  activeVersionId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  versions QuotationVersion[]

  @@map("quotations")
}

model QuotationVersion {
  id              String   @id @default(uuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id])
  versionNumber   Int
  isActive        Boolean  @default(true)
  subtotal        Decimal  @db.Decimal(12, 2)
  discount        Decimal  @default(0) @db.Decimal(12, 2)
  gstAmount       Decimal  @default(0) @db.Decimal(12, 2)
  transportation  Decimal  @default(0) @db.Decimal(12, 2)
  installation    Decimal  @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal  @db.Decimal(12, 2)
  createdByUserId String
  createdAt       DateTime @default(now())

  items      QuotationItem[]
  approvals  QuotationApproval[]
  projectServices ProjectService[]

  @@unique([quotationId, versionNumber])
  @@map("quotation_versions")
}

model QuotationItem {
  id                  String   @id @default(uuid())
  quotationVersionId  String
  quotationVersion    QuotationVersion @relation(fields: [quotationVersionId], references: [id])
  serviceId           String
  description         String
  quantity             Decimal @db.Decimal(10, 2)
  unitPrice            Decimal @db.Decimal(12, 2)
  taxRate               Decimal @db.Decimal(5, 2)
  taxAmount             Decimal @db.Decimal(12, 2)
  lineTotal             Decimal @db.Decimal(12, 2)

  @@map("quotation_items")
}

model QuotationApproval {
  id                  String   @id @default(uuid())
  quotationVersionId  String
  quotationVersion    QuotationVersion @relation(fields: [quotationVersionId], references: [id])
  approvedByUserId    String
  approvalMethod      ApprovalMethod
  approvedAt          DateTime @default(now())

  @@map("quotation_approvals")
}

// ==========================================================================
// M9 - PROJECT MODULE
// ==========================================================================

model Project {
  id            String    @id @default(uuid())
  projectNumber String    @unique
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id])
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  projectServices ProjectService[]
  invoices        Invoice[]
  documents       Document[]
  conversations   Conversation[]

  @@map("projects")
}

model ProjectService {
  id                       String   @id @default(uuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id])
  serviceId                String
  service                  Service  @relation(fields: [serviceId], references: [id])
  leadServiceId            String?
  leadService              LeadService? @relation(fields: [leadServiceId], references: [id])
  status                   String   @default("PROJECT CREATED")
  assignedQuotationVersionId String?
  assignedQuotationVersion QuotationVersion? @relation(fields: [assignedQuotationVersionId], references: [id])
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("project_services")
}

// ==========================================================================
// M10 - INVOICE & PAYMENT MODULE
// ==========================================================================

enum InvoiceStatus {
  ISSUED
  CANCELLED
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id])
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  label           String
  status          InvoiceStatus @default(ISSUED)
  cancelReason    String?
  subtotal        Decimal       @db.Decimal(12, 2)
  gstAmount       Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal       @db.Decimal(12, 2)
  issuedAt        DateTime      @default(now())
  createdByUserId String

  items    InvoiceItem[]
  payments Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  hsnSacCode  String
  taxRate     Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  @@map("invoice_items")
}

model Payment {
  id               String   @id @default(uuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id])
  amount           Decimal  @db.Decimal(12, 2)
  method           String
  referenceNote    String?
  recordedByUserId String
  paidAt           DateTime @default(now())

  @@map("payments")
}

model InvoiceNumberSequence {
  id           String @id @default(uuid())
  financialYear String @unique
  lastNumber   Int    @default(0)

  @@map("invoice_number_sequences")
}

// ==========================================================================
// M11 - DOCUMENTS MODULE
// ==========================================================================

model Document {
  id             String    @id @default(uuid())
  entityType     String    // LEAD | PROJECT
  entityId       String
  documentType   String
  fileName       String
  fileUrl        String
  fileSize       Int
  mimeType       String
  uploadedByUserId String
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id])
  projectRef     Project?  @relation(fields: [projectRefId], references: [id])
  projectRefId   String?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  @@index([entityType, entityId])
  @@map("documents")
}

// ==========================================================================
// M12 - MESSAGES MODULE
// ==========================================================================

model Conversation {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderType     String   // ADMIN | CLIENT
  senderUserId   String?
  senderClientId String?
  body           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("messages")
}
